{
  "name": "vscode-git-issues",
  "displayName": "Git Issues",
  "description": "Manage GitHub and GitLab issues directly from VSCode",
  "version": "1.3.0",
  "publisher": "tabsl",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tabsl/VS-Code-Git-Issues"
  },
  "bugs": {
    "url": "https://github.com/tabsl/VS-Code-Git-Issues/issues"
  },
  "homepage": "https://github.com/tabsl/VS-Code-Git-Issues#readme",
  "icon": "resources/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "github",
    "gitlab",
    "issues",
    "issue tracker",
    "git"
  ],
  "activationEvents": [
    "onView:gitIssues",
    "workspaceContains:.git"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-issues",
          "title": "Git Issues",
          "icon": "resources/icons/git-issues.svg"
        }
      ]
    },
    "views": {
      "git-issues": [
        {
          "id": "gitIssues",
          "name": "Issues"
        }
      ]
    },
    "commands": [
      {
        "command": "gitIssues.refresh",
        "title": "Refresh Issues",
        "icon": "$(refresh)",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.createIssue",
        "title": "Create Issue",
        "icon": "$(add)",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.filter",
        "title": "Filter Issues",
        "icon": "$(filter)",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.openIssue",
        "title": "Open Issue",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.openInBrowser",
        "title": "Open in Browser",
        "icon": "$(globe)",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.createBranchFromIssue",
        "title": "Create Branch from Issue",
        "icon": "$(git-branch)",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.selectRepository",
        "title": "Select Repository",
        "icon": "$(repo)",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.configureGitHubToken",
        "title": "Configure GitHub Token",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.configureGitLabToken",
        "title": "Configure GitLab Token",
        "category": "Git Issues"
      },
      {
        "command": "gitIssues.manageGitLabTokens",
        "title": "Manage GitLab Tokens",
        "category": "Git Issues"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "gitIssues.refresh",
          "when": "view == gitIssues",
          "group": "navigation@1"
        },
        {
          "command": "gitIssues.createIssue",
          "when": "view == gitIssues",
          "group": "navigation@2"
        },
        {
          "command": "gitIssues.filter",
          "when": "view == gitIssues",
          "group": "navigation@3"
        },
        {
          "command": "gitIssues.selectRepository",
          "when": "view == gitIssues && gitIssues.multipleRepositories",
          "group": "navigation@4"
        }
      ],
      "view/item/context": [
        {
          "command": "gitIssues.createBranchFromIssue",
          "when": "view == gitIssues && (viewItem == issue-open || viewItem == issue-closed)",
          "group": "inline"
        },
        {
          "command": "gitIssues.openInBrowser",
          "when": "view == gitIssues && (viewItem == issue-open || viewItem == issue-closed)",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "Git Issues",
      "properties": {
        "gitIssues.gitlab.url": {
          "type": "string",
          "default": "https://gitlab.com",
          "description": "GitLab instance URL (for self-hosted instances)"
        },
        "gitIssues.defaultState": {
          "type": "string",
          "enum": [
            "open",
            "closed",
            "all"
          ],
          "default": "open",
          "description": "Default issue state filter"
        },
        "gitIssues.defaultSort": {
          "type": "string",
          "enum": [
            "created",
            "updated",
            "comments"
          ],
          "default": "created",
          "description": "Default issue sort order"
        },
        "gitIssues.autoRefreshInterval": {
          "type": "number",
          "default": 0,
          "minimum": 0,
          "description": "Auto-refresh interval in seconds (0 to disable)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "build:webview": "cd src/webview/ui && npx vite build",
    "watch": "node esbuild.js --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vscode/vsce": "^3.7.1",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.1",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@gitbeaker/rest": "^40.0.0",
    "@octokit/rest": "^21.0.0",
    "dompurify": "^3.3.1",
    "marked": "^17.0.2"
  }
}
